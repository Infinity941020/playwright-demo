{
  "compilerOptions": {

    "target": "ES2020",

    "module": "CommonJS",

    "moduleResolution": "Node",

    "ignoreDeprecations": "6.0",

    "types": [
      "node",
      "@playwright/test"
    ],

    "strict": true,

    "esModuleInterop": true,

    "resolveJsonModule": true,

    "skipLibCheck": true,

    "noEmit": true,

    "rootDir": "."
  },

  "include": [
  "tests",
  "flows",
  "pages",
  "fixtures",
  "data",
  "utils",
  "playwright.config.ts"
]
}