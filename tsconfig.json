{
  "compilerOptions": {

    "target": "ES2020",

    "module": "Node16",

    "moduleResolution": "Node16",

    "types": [
      "node",
      "@playwright/test"
    ],

    "strict": true,

    "esModuleInterop": true,

    "resolveJsonModule": true,

    "skipLibCheck": true,

    "noEmit": true,

    "rootDir": "."
  },

  "include": [
    "tests",
    "flows",
    "pages",
    "fixtures",
    "data",
    "playwright.config.ts"
  ]
}